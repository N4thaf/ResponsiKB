{
    "version": 2,
    "builds": [
      {
        "src": "api/index.py",
        "use": "@vercel/python"
      },
      {
        "src": "requirements.txt",
        "use": "@vercel/static-build",
        "config": { "distDir": "." }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "api/index.py"
      }
    ],
    "env": {
      "PYTHON_VERSION": "3.10"
    }
  }